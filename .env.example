# THE WINDOW — environment template. Copy to .env (gitignored) or run:
#   cd packages/eerc-node && node src/gen_keys.mjs
# All keys below are throwaway TEST keys for the Fuji testnet only.

# ---- profile / network ----
PROFILE=DEMO                      # DEMO (seconds) | PROD (hours)
# Deploy honors these (DeployAll reads them). DEMO: 60s epoch / ~10-150 tenor blocks.
# PROD: 3600s epoch / 10800 tenor blocks (6h @ ~2s). Set per PROFILE when deploying.
# Fuji live stack: deploy_fuji.sh/run_fuji.sh default to EPOCH_LEN=120 TENOR_BLOCKS=60
# (epochs must outlast ~40s chunked-PoCD proving + real confirmations).
EPOCH_LEN=60                      # AuctionHouse epoch window, seconds
TENOR_BLOCKS=10                   # loan tenor in blocks (DEMO small so seize is reachable)
CONTROL_PORT=8899                 # Control API (dashboard write endpoints)
INDEXER_PORT=8787
RPC_LOCAL=http://127.0.0.1:8545   # the RPC services/lib/chain.mjs reads (run_fuji.sh points it at RPC_FUJI)
RPC_FUJI=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=31337                    # chain.mjs: selects contracts/deployments/<CHAIN_ID>.json (43113 = Fuji)
CHAIN_ID_FUJI=43113
START_BLOCK=0                     # earliest block the indexer scans; MUST be the deploy block on Fuji
                                  # (public RPCs cap eth_getLogs; live 43113 deploy block = 56937681)
KEEPER_STALL_S=120                # keeper stall-guard seconds; run_fuji.sh overrides to 300 for Fuji
# service poll cadence (ms) — defaults in code; run_fuji.sh sets all four to 5000
# KEEPER_POLL_MS=3000
# AGENTS_POLL_MS=3000
# ADMIN_POLL_MS=4000
# OPERATOR_POLL_MS=3000
# ALLOWLIST_POLL_MS=5000            # L1-only allowlist keeper (run_l1.sh); idle elsewhere
# LOG_WINDOW=2000                   # eth_getLogs pagination window (Fuji caps at 2048)
# BLOCK_SEC=2                       # display-only block-time estimate (loan deadlines/tenor)
SNOWTRACE_API_KEY=                # optional, for contract verification
RENDER_API_KEY=                   # optional, ops-only: trigger Render redeploys (notes/08)

# ---- actor EOAs (faucet-fund on Fuji: https://faucet.avax.network) ----
WALLET_PRIVATE_KEY=               # faucet-funded source wallet; scripts/fund_fuji.mjs REQUIRES it
LENDER1_PK=
LENDER2_PK=
BORROWER_PK=
ADMIN_PK=                         # also the eERC owner + auditor
KEEPER_PK=
VAULT_OPERATOR_PK=                # registered eERC EOA that custodies collateral
AGENT4_PK=                        # sim-agent bidders; REQUIRED by run_fuji.sh + fund_fuji.mjs
AGENT5_PK=

# ---- auditor BabyJubJub keypair (admin decrypts aggregates with this) ----
AUDITOR_BJJ_PRIV=
AUDITOR_BJJ_PUB_X=
AUDITOR_BJJ_PUB_Y=

# ---- deployed addresses ----
# Authoritative source: contracts/deployments/<chainid>.json (written by DeployAll).
# Services read the JSON directly — these are never required as env vars; the list
# below just mirrors the JSON keys for reference.
# TESTUSDC_ADDR=
# EERC_ADDR=
# REGISTRAR_ADDR=
# MEMBER_REGISTRY_ADDR=
# AUCTION_HOUSE_ADDR=
# MONIA_ORACLE_ADDR=
# COLLATERAL_VAULT_ADDR=
# LOAN_BOOK_ADDR=
