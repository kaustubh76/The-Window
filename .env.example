# THE WINDOW — environment template. Copy to .env (gitignored) or run:
#   cd packages/eerc-node && node src/gen_keys.mjs
# All keys below are throwaway TEST keys for the Fuji testnet only.

# ---- profile / network ----
PROFILE=DEMO                      # DEMO (seconds) | PROD (hours)
RPC_LOCAL=http://127.0.0.1:8545
RPC_FUJI=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID_FUJI=43113
SNOWTRACE_API_KEY=                # optional, for contract verification

# ---- actor EOAs (faucet-fund on Fuji: https://faucet.avax.network) ----
LENDER1_PK=
LENDER2_PK=
BORROWER_PK=
ADMIN_PK=                         # also the eERC owner + auditor
KEEPER_PK=
VAULT_OPERATOR_PK=                # registered eERC EOA that custodies collateral

# ---- auditor BabyJubJub keypair (admin decrypts aggregates with this) ----
AUDITOR_BJJ_PRIV=
AUDITOR_BJJ_PUB_X=
AUDITOR_BJJ_PUB_Y=

# ---- deployed addresses (written by deploy script to contracts/deployments/<net>.json) ----
# TESTUSDC_ADDR=
# EERC_ADDR=
# BABYJUBJUB_ADDR=
# MEMBER_REGISTRY_ADDR=
# AUCTION_HOUSE_ADDR=
# MONIA_ORACLE_ADDR=
# COLLATERAL_VAULT_ADDR=
# LOAN_BOOK_ADDR=
