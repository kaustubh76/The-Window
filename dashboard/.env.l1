# Dashboard config for the permissioned L1 (thewindowl1, 43117).
# Loaded by Vite for `npm run dev -- --mode l1` (or `npm run build -- --mode l1`).
# The browser talks HTTP only to the L1 indexer (:8788, READ_GATE on) + control (:8900);
# it never hits the raw avalanche RPC, so no VITE_RPC_L1 is needed. Addresses are the
# DETERMINISTIC contracts/deployments/43117.json set (same every local deploy).
VITE_PROFILE=DEMO
VITE_CHAIN_ID=43117
VITE_READ_GATE=1
VITE_INDEXER_URL=http://127.0.0.1:8788
VITE_CONTROL_URL=http://127.0.0.1:8900

# deployed addresses (deployments/43117.json)
VITE_TESTUSDC_ADDR=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
VITE_EERC_ADDR=0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6
VITE_REGISTRAR_ADDR=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
