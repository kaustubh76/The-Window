# Dashboard config for the permissioned L1 (thewindowl1, 43117).
# Loaded by Vite for `npm run dev -- --mode l1` (or `npm run build -- --mode l1`).
# The browser talks HTTP only to the L1 indexer (:8788, READ_GATE on) + control (:8900);
# it never hits the raw avalanche RPC, so no VITE_RPC_L1 is needed. The addresses below
# mirror contracts/deployments/43117.json — refresh them from that file after each live-only
# redeploy (the real-key deployer yields a fresh, deterministic contract set). Role addrs
# (VITE_ADMIN_ADDR / VITE_KEEPER_ADDR) are the real Fuji ops EOAs, matching l1/genesis.json.
VITE_PROFILE=DEMO
VITE_CHAIN_ID=43117
VITE_READ_GATE=1
VITE_INDEXER_URL=http://127.0.0.1:8788
VITE_CONTROL_URL=http://127.0.0.1:8900

# deployed addresses (contracts/deployments/43117.json — live-only Fuji-anchored redeploy,
# BlockchainID 2RYFbSrnvpJr9RRxHufD7w2rUoZahffZJ8xbp7DytSPH1VxiuY; real-ADMIN deployer)
VITE_TESTUSDC_ADDR=0x69FeBF0674ffea0ddf6BbFaD554582d9e5DB0bCF
VITE_EERC_ADDR=0xa3F9e88dfFd25ceb64dc040498c9F2Ce50f8C0a2
VITE_REGISTRAR_ADDR=0x6603f2485B9B5d8c705400abF7241D4f9e183bF9
VITE_MEMBER_REGISTRY_ADDR=0x14c8173279FB3F28B6fE9b0423Ff535C0cBaD7F8
VITE_AUCTION_HOUSE_ADDR=0xd001d287d7e62fE1118C42E49E3fe461e010a71e
VITE_MONIA_ORACLE_ADDR=0xD1979c145d70009e6D84AB82A590E13a0026CEc2
VITE_COLLATERAL_VAULT_ADDR=0x9C948B4dA40F017102dAAe78afd956829E32d05e
VITE_LOAN_BOOK_ADDR=0x42215B392c3C22Af3fbBE45d370114C43F536031
VITE_ADMIN_ADDR=0x6358c6B980fad929247b932207893b4dB2F7cd82
