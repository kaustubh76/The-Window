# THE WINDOW dashboard — environment template. Copy to .env.local (gitignored).

# ---- data source ----
# The app is live-only: services/indexer REST reads + Control API writes — the server
# does all eERC proving; the browser never holds keys or circuit artifacts. Point the
# two URLs below at your local services or the hosted Render deployment.

# ---- time profile ----
# DEMO = seconds (epoch 60s, tenor 5m).  PROD = hours (epoch 1h, tenor 6h).
VITE_PROFILE=DEMO

# ---- chain (live mode) ----
VITE_CHAIN_ID=43113
VITE_RPC_FUJI=https://api.avax-test.network/ext/bc/C/rpc
VITE_RPC_LOCAL=http://127.0.0.1:8545
VITE_INDEXER_URL=/api
VITE_CONTROL_URL=http://127.0.0.1:8899
VITE_SNOWTRACE_URL=https://testnet.snowtrace.io
# Public hosted Fuji indexer — read by the /l1 competitor pane to show the real
# participation leak on a public chain. Defaults to the Render deployment.
VITE_FUJI_INDEXER_URL=https://window-indexer.onrender.com
# Member-signature-gated indexer reads. "1" turns on the read-gate; auto-on when
# VITE_CHAIN_ID=43117 (the permissioned L1). Off on Fuji/local (public hard mode).
VITE_READ_GATE=0

# ---- deployed addresses (live mode; filled by the deploy script) ----
VITE_TESTUSDC_ADDR=
VITE_EERC_ADDR=
VITE_REGISTRAR_ADDR=
VITE_MEMBER_REGISTRY_ADDR=
VITE_AUCTION_HOUSE_ADDR=
VITE_MONIA_ORACLE_ADDR=
VITE_COLLATERAL_VAULT_ADDR=
VITE_LOAN_BOOK_ADDR=

# ---- ops role addresses (for persona gating in live mode) ----
VITE_ADMIN_ADDR=
VITE_KEEPER_ADDR=
