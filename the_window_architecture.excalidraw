   "updated": 1720000000000,
   "link": null,
   "locked": false,
   "text": "WHY THIS WINS A SPEEDRUN — finished-and-true beats ambitious-and-broken",
   "originalText": "WHY THIS WINS A SPEEDRUN — finished-and-true beats ambitious-and-broken",
   "fontSize": 15,
