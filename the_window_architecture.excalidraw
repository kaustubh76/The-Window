   "id": "z_solvency_t",
   "type": "text",
   "x": 970,
   "y": 1382,
   "width": 303.59999999999997,
   "height": 55,
   "text": "collateral_solvency.circom\nproves Dec(coll)·10000 ≥ Dec(loan)·12000 (120%\nhaircut) + key-binding; reuses eERC\nCheckPublicKey/CheckValue",
   "originalText": "collateral_solvency.circom\nproves Dec(coll)·10000 ≥ Dec(loan)·12000 (120%\nhaircut) + key-binding; reuses eERC\nCheckPublicKey/CheckValue",
