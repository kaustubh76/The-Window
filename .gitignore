# secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
keys/

# node
node_modules/
dist/
*.log
npm-debug.log*

# foundry
contracts/out/
contracts/cache/
contracts/broadcast/**/dry-run/

# circuits — all build output is regenerable via `make circuits` (ptau/zkey/wasm/
# r1cs/witness/proofs). The committed test dependency lives in contracts/test/fixtures/.
circuits/build/
*.ptau

# foundry run artifacts (ephemeral, local)
contracts/broadcast/
contracts/deployments/*.json

# services / indexer data
services/**/artifacts/
*.sqlite
*.db

# dashboard
dashboard/dist/
dashboard/.vite/
dashboard/.vercel_static/
dashboard/.vercel/

# os
.DS_Store
