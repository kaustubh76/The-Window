# secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
*.key
keys/

# node
node_modules/
dist/
*.log
npm-debug.log*

# foundry
contracts/out/
contracts/cache/
contracts/broadcast/**/dry-run/

# circuits — all build output is regenerable via `make circuits` (ptau/zkey/wasm/
# r1cs/witness/proofs). The committed test dependency lives in contracts/test/fixtures/.
circuits/build/
*.ptau

# foundry run artifacts (ephemeral, local) — EXCEPT the live Fuji deployment:
# the 43113 addresses + broadcast receipts are committed so a fresh clone gets
# machine-readable addresses and on-chain provenance (public data only).
contracts/broadcast/*
!contracts/broadcast/DeployAll.s.sol/
contracts/broadcast/DeployAll.s.sol/*
!contracts/broadcast/DeployAll.s.sol/43113/
contracts/broadcast/DeployAll.s.sol/43113/*
!contracts/broadcast/DeployAll.s.sol/43113/run-latest.json
contracts/deployments/*.json
!contracts/deployments/43113.json

# services / indexer data
services/**/artifacts/
*.sqlite
*.db
# fast-resume snapshot — a build artifact baked into the image (regenerated per build via
# scripts/gen_indexer_snapshot.mjs), like contracts/out + circuits/build. Don't churn git with it.
services/indexer/snapshot.json

# dashboard
dashboard/dist/
dashboard/.vite/
dashboard/.vercel_static/
dashboard/.vercel/

# os
.DS_Store
services/control/dynamic-actors.json
